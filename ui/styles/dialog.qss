/* =========================================================
   DIALOG CONTAINER
   ========================================================= */
QWidget[role="dialog"][variant="confirm"] {
    background-color: #1a1a1a;
    border: 2px solid #0078d4;
    border-radius: 15px;
}

/* =========================================================
   DIALOG PARTS
   ========================================================= */
QLabel[role="dialog"][variant="title"] {
    font-size: 18px;
    font-weight: bold;
    color: #ffffff;
}

QLabel[role="dialog"][variant="message"] {
    font-size: 14px;
    color: #cccccc;
    padding: 10px;
}

/* =========================================================
   ACTION BUTTON – BASE
   ========================================================= */
QPushButton[role="action"] {
    min-height: 45px;
    min-width: 120px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: bold;
    border: none;
}

/* =========================================================
   ACTION STATES
   ========================================================= */

/* ---------- CONFIRM ---------- */
QPushButton[role="action"][state="confirm"] {
    background-color: #10B981;
    color: white;
}

QPushButton[role="action"][state="confirm"]:hover {
    background-color: #059669;
}

QPushButton[role="action"][state="confirm"]:pressed {
    background-color: #047857;
}

/* ---------- CANCEL ---------- */
QPushButton[role="action"][state="cancel"] {
    background-color: #DC2626;
    color: white;
}

QPushButton[role="action"][state="cancel"]:hover {
    background-color: #B91C1C;
}

QPushButton[role="action"][state="cancel"]:pressed {
    background-color: #991B1B;
}

QPushButton[role="action"]:disabled {
    background-color: #121212;
    color: #777;
}


QPushButton[role="angle-input"] {
    background-color: #0078d4;
    color: white;
    border-radius: 5px;
    font-size: 11px;
    font-weight: bold;
}

QPushButton[role="angle-input"]:hover {
    background-color: #106ebe;
}

QPushButton[role="angle-input"]:pressed {
    background-color: #005a9e;
}

QWidget[role="dialog"][variant="angle-input"] {
    background-color: #111827;
    border: 1px solid #374151;
    border-radius: 12px;
}
